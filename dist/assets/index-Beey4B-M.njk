{% extends "_layout.njk" %}

{% set title = "Lumio Studio — Digital experiences with clarity" %}
{% set description = "Lumio Studio creates thoughtful digital brands and experiences." %}
{% set activePage = "home" %}

{% block content %}
<section class="hero-section overflow-hidden">
  <div class="container py-5 py-lg-6">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <p class="eyebrow mb-3">Independent creative studio · India</p>
        <h1 class="display-2 fw-semibold lh-sm mb-4">Digital experiences with <em>clarity.</em></h1>
        <p class="lead text-secondary col-lg-10 mb-4">We help ambitious brands find their voice, shape useful products, and show up beautifully online.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-center">
          <a class="btn btn-dark btn-lg rounded-pill px-4" href="contact.html">Let's work together <span aria-hidden="true">→</span></a>
          <a class="link-dark link-offset-2" href="#work">Explore our work</a>
        </div>
      </div>
      <div class="col-lg-5">
        <img src="/images/falling-760x435.jpg" alt="Digital experiences visualization" class="img-fluid rounded-3" style="box-shadow: 0 12px 30px rgba(0,0,0,0.15);">
      </div>
    </div>
  </div>
</section>

{% extends "_layout.njk" %}

{% set title = "Lumio Studio — Digital experiences with clarity" %}
{% set description = "Lumio Studio creates thoughtful digital brands and experiences." %}
{% set activePage = "home" %}

{% block content %}
<section class="hero-section overflow-hidden">
  <div class="container py-5 py-lg-6">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <p class="eyebrow mb-3">Independent creative studio · India</p>
        <h1 class="display-2 fw-semibold lh-sm mb-4">Digital experiences with <em>clarity.</em></h1>
        <p class="lead text-secondary col-lg-10 mb-4">We help ambitious brands find their voice, shape useful products, and show up beautifully online.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 align-items-sm-center">
          <a class="btn btn-dark btn-lg rounded-pill px-4" href="contact.html">Let's work together <span aria-hidden="true">→</span></a>
          <a class="link-dark link-offset-2" href="#work">Explore our work</a>
        </div>
      </div>
      <div class="col-lg-5">
        <img src="/images/falling-760x435.jpg" alt="Digital experiences visualization" class="img-fluid rounded-3" style="box-shadow: 0 12px 30px rgba(0,0,0,0.15);">
      </div>
    </div>
  </div>
</section>

<section class="border-top border-bottom py-4" aria-label="Studio capabilities">
  <div class="container">
    <div class="row g-3 text-center small fw-semibold text-uppercase letter-spacing">
      <div class="col-6 col-md-3">Brand strategy</div>
      <div class="col-6 col-md-3">Visual identity</div>
      <div class="col-6 col-md-3">Web design</div>
      <div class="col-6 col-md-3">Creative direction</div>
    </div>
  </div>
</section>

<section class="py-5 py-lg-6" id="work">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4 mb-lg-5">
      <div>
        <p class="eyebrow mb-2">Selected work</p>
        <h2 class="display-6 fw-semibold mb-0">Built for a lasting impression.</h2>
      </div>
      <a class="d-none d-md-inline-block link-dark" href="about.html">How we work →</a>
    </div>
    <div id="workCarousel" class="carousel slide work-carousel" data-bs-ride="carousel">
      <div class="carousel-inner">
        <div class="carousel-item active">
          <div class="project-panel project-sage">
            <div class="row align-items-center h-100 g-4">
              <div class="col-md-6 p-4 p-lg-5">
                <p class="eyebrow">Brand identity · 2026</p>
                <h3 class="display-5 fw-semibold">Noma<br>Objects</h3>
                <p class="mb-0 text-secondary">A quieter identity for objects that make everyday rituals feel special.</p>
              </div>
              <div class="col-md-6 d-flex align-items-center justify-content-center">
                <img src="/images/object-removebg-preview.png" alt="Noma Objects" class="img-fluid" style="max-height: 300px;">
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-item">
          <div class="project-panel project-coral">
            <div class="row align-items-center h-100 g-4">
              <div class="col-md-6 p-4 p-lg-5">
                <p class="eyebrow">Digital product · 2026</p>
                <h3 class="display-5 fw-semibold">Field<br>Notes</h3>
                <p class="mb-0 text-secondary">An intuitive online journal for people who prefer to look up and go outside.</p>
              </div>
              <div class="col-md-6 d-flex align-items-center justify-content-center">
                <img src="/images/notesbook-removebg-preview.png" alt="Field Notes" class="img-fluid" style="max-height: 300px;">
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-item">
          <div class="project-panel project-lilac">
            <div class="row align-items-center h-100 g-4">
              <div class="col-md-6 p-4 p-lg-5">
                <p class="eyebrow">Campaign · 2025</p>
                <h3 class="display-5 fw-semibold">After<br>Hours</h3>
                <p class="mb-0 text-secondary">A bright, playful launch campaign for an independent music collective.</p>
              </div>
              <div class="col-md-6 d-flex align-items-center justify-content-center">
                <img src="/images/after_hours-removebg-preview.png" alt="After Hours" class="img-fluid" style="max-height: 300px;">
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="d-flex gap-2 mt-3">
        <button class="carousel-control-prev position-static carousel-button" type="button" data-bs-target="#workCarousel" data-bs-slide="prev"><span aria-hidden="true">←</span><span class="visually-hidden">Previous</span></button>
        <button class="carousel-control-next position-static carousel-button" type="button" data-bs-target="#workCarousel" data-bs-slide="next"><span aria-hidden="true">→</span><span class="visually-hidden">Next</span></button>
      </div>
    </div>
  </div>
</section>

<section class="py-5 py-lg-6 bg-ink text-white">
  <div class="container">
    <div class="row g-5">
      <div class="col-lg-5">
        <p class="eyebrow text-white-50">What we do</p>
        <h2 class="display-6 fw-semibold">Less noise.<br>More meaning.</h2>
      </div>
      <div class="col-lg-7">
        <div class="row g-3">
          <div class="col-md-6">
            <article class="service-card">
              <span>01</span>
              <h3>Strategy</h3>
              <p>Clear positioning and a practical creative direction before design begins.</p>
            </article>
          </div>
          <div class="col-md-6">
            <article class="service-card">
              <span>02</span>
              <h3>Identity</h3>
              <p>Distinct visual systems that stay recognisable wherever your brand appears.</p>
            </article>
          </div>
          <div class="col-md-6">
            <article class="service-card">
              <span>03</span>
              <h3>Websites</h3>
              <p>Responsive, accessible websites that make your next step easy to take.</p>
            </article>
          </div>
          <div class="col-md-6">
            <article class="service-card">
              <span>04</span>
              <h3>Campaigns</h3>
              <p>Flexible ideas that turn attention into genuine connection.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-5 py-lg-6">
  <div class="container">
    <div class="cta-panel text-center">
      <p class="eyebrow mb-3">Have a good idea?</p>
      <h2 class="display-5 fw-semibold mx-auto mb-4">Let's give it a shape people remember.</h2>
      <a class="btn btn-dark btn-lg rounded-pill px-4" href="contact.html">Start a conversation →</a>
    </div>
  </div>
</section>
{% endblock %}
